{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NexusVoice",
  "version": "1.4.3",
  "identifier": "com.nexusvoice.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NexusVoice",
        "width": 1200,
        "height": 800,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "backgroundColor": "#22232b",
        "url": "index.html"
      },
      {
        "label": "pill",
        "title": "Recording Pill",
        "width": 104,
        "height": 32,
        "visible": false,
        "create": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "url": "pill.html"
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "upgradeCode": "8a3c9a7e-1234-4b5d-89ab-cdef01234567"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBOTlFRDAyRUNDQUVDRUEKUldUcTdNcnNBdTJaaWhydmo0cmIwRzRXNk1aUEdsRU04VjZzaXVKZG9peG8wU0cvRHlmQVhUUGcK",
      "endpoints": [
        "https://github.com/Ved-Padmawar/NexusVoice/releases/latest/download/latest.json"
      ]
    }
  }
}
